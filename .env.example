# Stock Journal local settings
STOCK_APP_HOST=127.0.0.1
STOCK_APP_PORT=8000

# Firebase Web config (public, loaded by frontend from /api/auth/config)
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
# Optional web config fields
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=1234567890

# Firebase Admin SDK credential path (server-side only, DO NOT commit)
# Either set this path OR use GOOGLE_APPLICATION_CREDENTIALS/ADC on host
FIREBASE_SERVICE_ACCOUNT_JSON=/absolute/path/to/firebase-service-account.json

# Legacy Google OAuth routes (kept for compatibility in Phase A)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Optional login restrictions
# STOCK_ALLOWED_GOOGLE_EMAILS=user1@gmail.com,user2@gmail.com
# STOCK_ALLOWED_GOOGLE_DOMAIN=example.com

# Use true only when serving over HTTPS
STOCK_COOKIE_SECURE=false
